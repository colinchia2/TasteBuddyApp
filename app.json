{
  "expo": {
    "name": "TasteBuddy",
    "slug": "tastebuddy",
    "scheme": "tastebuddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.colinchia.tastebuddy"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-media-library",
        {
          "photosPermission": "TasteBuddy uses your photos so you can attach them to your visits.",
          "savePhotosPermission": "TasteBuddy uses your photos so you can attach them to your visits.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TasteBuddy uses your location to check you in at Places and find spots near you."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TasteBuddy needs access to your photos so you can attach pictures to your visits.",
          "cameraPermission": "TasteBuddy needs camera access so you can take photos of your visits."
        }
      ],
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
